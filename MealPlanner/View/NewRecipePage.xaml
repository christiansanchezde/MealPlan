<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MealPlanner.View.NewRecipePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:MealPlanner.ViewModel"
    xmlns:model="clr-namespace:MealPlanner.Model"
    x:DataType="viewmodel:NewRecipeViewModel"
    Title="{Binding Title}"
    x:Name="Page">

    <ScrollView>
        <Grid Padding="20" RowSpacing="12">

            <!-- 1. Define all rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Title -->
                <RowDefinition Height="Auto" />
                <!-- Recipe Name -->
                <RowDefinition Height="Auto" />
                <!-- Ingredients Label -->
                <RowDefinition Height="Auto" />
                <!-- Ingredients Input -->
                <RowDefinition Height="*"    />
                <!-- Added ingredients list -->
                <RowDefinition Height="Auto" />
                <!-- “Add new ingredient” -->
                <RowDefinition Height="Auto" />
                <!-- Instructions Label -->
                <RowDefinition Height="Auto" />
                <!-- Instructions Editor -->
                <RowDefinition Height="Auto" />
                <!-- Save button -->
            </Grid.RowDefinitions>

            <!-- 2. Page title -->
            <Label
        Grid.Row="0"
        Text="New Recipe"
        FontSize="24"
        FontAttributes="Bold" />

            <!-- 3. Recipe name -->
            <Entry
        Grid.Row="1"
        Placeholder="Name"
        Text="{Binding RecipeName}" />

            <!-- 4. “Ingredients” label -->
            <Label
        Grid.Row="2"
        Text="Ingredients"
        FontAttributes="Bold" />

            <!-- 5. Single-row grid to pick + qty + unit + add -->
            <Grid Grid.Row="3" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Picker
          Grid.Column="0"
          Title="Select ingredient"
          ItemsSource="{Binding IngredientList}"
          SelectedItem="{Binding AddIngredientName}" />

                <Entry
          Grid.Column="1"
          Keyboard="Numeric"
          Placeholder="Qty"
          Text="{Binding AddIngredientQuantity}" />

                <Label
          Grid.Column="2"
          Text="{Binding AddIngredientUnit}"
          VerticalOptions="Center" />

                <Button
          Grid.Column="3"
          Text="Add"
          Command="{Binding AddNewIngredientCommand}" />
            </Grid>

            <!-- 6. List of added ingredients -->
            <CollectionView
        Grid.Row="4"
        ItemsSource="{Binding Ingredients}"
        SelectionMode="None"
        EmptyView="No ingredients added yet">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:IngredientInfo">
                        <Grid Padding="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Text="{Binding Name}" />
                            <Label Grid.Column="1" Text="{Binding Quantity}" />
                            <Label Grid.Column="2" Text="{Binding Unit}" />

                            <!-- Remove button must point back up to your VM -->
                            <Button
                Grid.Column="3"
                Text="Remove"
                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:NewRecipeViewModel}}, Path=RemoveIngredientCommand}"
                CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- 7. Stub to add new ingredient type -->
            <Button
        Grid.Row="5"
        Text="Add new ingredient"
        Command="{Binding AddNewIngredientTypeCommand}" />

            <!-- 8. Instructions -->
            <Label
        Grid.Row="6"
        Text="Instructions"
        FontAttributes="Bold" />

            <Editor
        Grid.Row="7"
        HeightRequest="200"
        Placeholder="Enter preparation instructions"
        Text="{Binding Preparation}" />

            <!-- 9. Save -->
            <Button
        Grid.Row="8"
        Text="Save Recipe"
        Command="{Binding SaveRecipeCommand}"
        HorizontalOptions="Center" />

        </Grid>
    </ScrollView>
</ContentPage>
